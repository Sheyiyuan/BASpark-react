{
  "name": "baspark-react",
  "version": "0.1.0",
  "description": "Blue Archive style mouse spark effect React component",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "react",
    "typescript",
    "mouse-effect",
    "spark",
    "particle",
    "canvas",
    "blue-archive",
    "click-effect",
    "animation"
  ],
  "author": "Sheyiyuan",
  "contributors": [
    {
      "name": "Doom",
      "url": "https://github.com/DoomVoss",
      "role": "Original BASpark author (WPF + WebView2)"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sheyiyuan/BASpark"
  },
  "bugs": {
    "url": "https://github.com/Sheyiyuan/BASpark/issues"
  },
  "homepage": "https://github.com/Sheyiyuan/BASpark#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "docs:install": "pnpm --dir docs install",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "publishConfig": {
    "access": "public"
  }
}