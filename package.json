{
  "name": "baspark-react",
  "version": "1.0.0",
  "description": "Blue Archive style mouse spark effect React component",
  "main": "MouseSparkReact.tsx",
  "module": "MouseSparkReact.tsx",
  "types": "MouseSparkReact.tsx",
  "exports": {
    ".": {
      "import": "./MouseSparkReact.tsx",
      "types": "./MouseSparkReact.tsx",
      "default": "./MouseSparkReact.tsx"
    }
  },
  "keywords": [
    "react",
    "typescript",
    "mouse-effect",
    "spark",
    "particle",
    "canvas",
    "blue-archive",
    "click-effect",
    "animation"
  ],
  "author": "Doom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DoomVoss/BASpark"
  },
  "bugs": {
    "url": "https://github.com/DoomVoss/BASpark/issues"
  },
  "homepage": "https://doomvoss.github.io/BASpark/",
  "files": [
    "MouseSparkReact.tsx",
    "index.ts",
    "examples.tsx",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "docs:install": "cd docs && npm install",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "docs:preview": "cd docs && npm run preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
